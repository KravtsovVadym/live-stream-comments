# ------------------------------------------------
# ---- Backend Environment configuration variables
# ------------------------------------------------


# ---- Security
SECRET_KEY=your-secret-key-here
DEBUG=True

# ---- PostgreSQL Database - database settings
POSTGRES_DB=comments_db
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin
POSTGRES_HOST=db
POSTGRES_PORT=5432

DATABASE_URL=postgres://admin:admin@db:5432/comments_db

# ---- Redis settings for WebSockets
REDIS_URL=redis://127.0.0.1:6379

# ---- Allowed origins for CORS (local dev)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ---- Allowed hosts - comma-separated domains
ALLOWED_HOSTS=127.0.0.1,localhost

# ---- Cloudinary get on (cloudinary.com/console)
USE_CLOUDINARY=False
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=your-api-secret-here

